# =============================================================================
# Life Tracker — copy this file to .env and fill in real values (never commit .env)
# =============================================================================

# Telegram Bot (see README: "Telegram bot token and user ID")
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_USER_ID=your_numeric_telegram_user_id

# Google Gemini (see README: "Gemini API key")
GEMINI_API_KEY=your_gemini_api_key
# Optional: must match a model enabled for your key (e.g. gemini-2.5-flash, gemini-2.0-flash)
GEMINI_MODEL=gemini-2.5-flash

# Fitbit Web API (see README: "Fitbit app credentials")
FITBIT_CLIENT_ID=your_fitbit_client_id
FITBIT_CLIENT_SECRET=your_fitbit_client_secret
FITBIT_REDIRECT_URI=http://localhost:8080/fitbit/callback

# Gmail SMTP (see README: "Gmail app password")
GMAIL_ADDRESS=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
NOTIFICATION_EMAIL=your_email@gmail.com

# Budget defaults
DEFAULT_CURRENCY=INR
DEFAULT_MONTHLY_BUDGET=50000

# Notification times (24h format)
DAILY_SUMMARY_HOUR=21
EVENING_NUDGE_HOUR=20
WEEKLY_SUMMARY_DAY=mon
WEEKLY_SUMMARY_HOUR=9

# Fitbit sync interval in hours
FITBIT_SYNC_INTERVAL_HOURS=4

# Database
DB_PATH=data/life_tracker.db
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=30
